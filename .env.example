# ─────────────────────────────────────────────────────────
# Aidos Bot — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────

# ── Telegram ──────────────────────────────────────────────
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ── Google Gemini ──────────────────────────────────────────
# Get from https://aistudio.google.com/apikey (free tier)
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model to use (default: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# ── Access Control ─────────────────────────────────────────
# Comma-separated Telegram user IDs allowed to use the bot
# Find your ID by messaging @userinfobot on Telegram
ALLOWED_USER_IDS=123456789,987654321

# Comma-separated Telegram user IDs with admin privileges
# Admins can run /allow, /revoke, /users commands
ADMIN_USER_IDS=123456789

# ── Database ───────────────────────────────────────────────
# Path to SQLite database file (inside container: /app/data/aidos.db)
DATABASE_PATH=data/aidos.db

# ── Logging ────────────────────────────────────────────────
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ── History ────────────────────────────────────────────────
# Maximum translation history entries per user (default: 1000)
# Oldest entries are deleted when cap is exceeded
# HISTORY_CAP=1000
